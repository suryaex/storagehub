# ──────────────────────────────────────────────────────────────
# StorageHub environment template — copy to .env and edit values
# ──────────────────────────────────────────────────────────────

# App
# Host port the nginx reverse proxy publishes (8080 avoids clashing with SecureOps :80)
HTTP_PORT=8080
APP_NAME=StorageHub
APP_VERSION=1.0
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
# Comma-separated CORS origins
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# Enable passwordless local login for development (DISABLE in production)
ALLOW_LOCAL_LOGIN=true

# Database (compose uses the mysql service hostname "mysql")
DATABASE_URL=mysql+pymysql://storagehub:storagehub@mysql:3306/storagehub
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=storagehub
MYSQL_USER=storagehub
MYSQL_PASSWORD=storagehub

# Storage
STORAGE_ROOT=/data/storage
DEFAULT_USER_QUOTA=10737418240        # 10 GiB
MAX_UPLOAD_SIZE=53687091200           # 50 GiB
UPLOAD_CHUNK_SIZE=8388608             # 8 MiB
TRASH_RETENTION_DAYS=30

# ── OAuth providers (optional — leave blank to disable a provider) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Generic OIDC
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=

# Frontend (Vite) — used at build time
VITE_API_BASE_URL=/api/v1

# ── Service-to-service ingest (SecureOps log backup) ──
# Comma-separated secret keys accepted in the X-API-Key header on /api/v1/ingest/*.
# Generate one: openssl rand -hex 32
SERVICE_API_KEYS=
# Send HSTS header (enable only when served strictly over HTTPS)
ENABLE_HSTS=false
